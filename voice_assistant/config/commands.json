{
  "brightness": {
    "keywords": ["brightness", "bright", "light", "screen"],
    "actions": {
      "absolute_increase": {
        "patterns": [
          "increase brightness to maximum",
          "brightness maximum", 
          "full brightness now",
          "max brightness",
          "brightest",
          "full bright",
          "light maximum",
          "screen brightest"
        ],
        "value": 100,
        "description": "Set brightness to 100%"
      },
      "absolute_decrease": {
        "patterns": [
          "decrease brightness to minimum",
          "brightness minimum",
          "turn off brightness",
          "min brightness",
          "darkest",
          "zero brightness",
          "light minimum",
          "screen darkest"
        ],
        "value": 0,
        "description": "Set brightness to 0%"
      },
      "relative_increase": {
        "patterns": [
          "brightness up",
          "increase brightness slightly", 
          "brighten up",
          "bright up",
          "more brightness",
          "brighter",
          "increase bright",
          "light up",
          "screen up"
        ],
        "step": 5,
        "description": "Increase brightness by 5%"
      },
      "relative_decrease": {
        "patterns": [
          "brightness down",
          "decrease brightness slightly",
          "dim down", 
          "bright down",
          "less brightness",
          "dimmer",
          "decrease bright",
          "light down",
          "screen down"
        ],
        "step": 5,
        "description": "Decrease brightness by 5%"
      },
      "set_value": {
        "patterns": [
          "set brightness {value}",
          "brightness level {value}",
          "adjust brightness to {value}",
          "brightness {value}",
          "bright to {value}",
          "light to {value}",
          "screen to {value}"
        ],
        "value_range": [0, 100],
        "description": "Set brightness to specific value (0-100)"
      }
    }
  },
