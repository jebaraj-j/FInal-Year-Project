{
  "brightness": {
    "keywords": ["brightness", "bright"],
    "actions": {
      "absolute_increase": {
        "patterns": [
          "increase brightness",
          "maximum brightness",
          "full brightness",
          "brightest"
        ],
        "value": 100,
        "description": "Set brightness to 100%"
      },
      "absolute_decrease": {
        "patterns": [
          "decrease brightness",
          "minimum brightness",
          "zero brightness",
          "darkest",
          "turn off brightness"
        ],
        "value": 0,
        "description": "Set brightness to 0%"
      },
      "relative_increase": {
        "patterns": [
          "brightness up",
          "increase bright",
          "bright up",
          "more brightness",
          "brighter"
        ],
        "step": 2,
        "description": "Increase brightness by 2%"
      },
      "relative_decrease": {
        "patterns": [
          "brightness down",
          "decrease bright",
          "bright down",
          "less brightness",
          "dimmer"
        ],
        "step": 2,
        "description": "Decrease brightness by 2%"
      },
      "set_value": {
        "patterns": [
          "set brightness {value}",
          "brightness {value}",
          "bright to {value}",
          "set bright {value}"
        ],
        "value_range": [0, 100],
        "description": "Set brightness to specific value (0-100)"
      }
    }
  },
